    ],
    "performance_case_ids": [
      "chunk_scaled_dot_kkt_performance"
    ]
  },
  "tolerance": {
    "float16": {
      "rtol": 0.003,
      "atol": 0.003
    },
    "bfloat16": {
      "rtol": 0.006,
      "atol": 0.006
    }
  },
