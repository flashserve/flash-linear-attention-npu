{
  "schema_version": 1,
  "op": "chunk_scaled_dot_kkt",
  "implementation": "ascendc",
  "model": "gdn",
  "symbol_table_version": "gdn-shape-v1",
  "capability": {
    "soc": [
      "ascend910b",
      "ascend910_93",
      "ascend950"
    ],
    "dtypes": [
      "bfloat16",
      "float16",
      "float32"
    ],
    "layouts": [
      "BNSD"
    ],
    "features": [
      "fixed/varlen",
      "GVA 输入",
      "整块/尾块"
    ],
    "routes": [
      "ascendc",
      "aclnn",
      "direct_launch"
    ],
    "optional_routes": [
      "torch_ops_npu"
    ]
  },
  "data_generation": {
    "floating_inputs": {
      "distribution": "uniform",
      "min": -1.0,
      "max": 1.0
    },
    "positive_inputs": {
      "distribution": "uniform",
      "min": 0.0,
      "max": 1.0
    },
    "structured_inputs": "由 reference 名称对应的 runner 构造 gate、三角矩阵、状态和索引"
  },
  "coverage_requirements": {
    "public_modes": [
      "fixed/varlen",
      "GVA 输入",
      "整块/尾块"
    ],
    "known_limits": [
      "chunk_size 仅支持 16/32/64/128。",
      "必须满足 H_v % H_k == 0；A 的 head 维为 H_k。",
      "cu_seqlens/chunk_indices 必须同时提供或同时省略；varlen 物理 B 必须为 1。",
      "varlen 累计长度必须覆盖 [0,T]，chunk_indices 必须按 sequence-major 完整列出每个 C 大小的 chunk。",
      "指数差固定 clip 到 [-50,50]；H_v>H_k 时当前实现读取 g/beta 的前 H_k 个 head。"
    ],
    "required_outputs": [
      "A"
    ],
    "accuracy_case_ids": [
      "chunk_scaled_dot_kkt_main_accuracy",
      "chunk_scaled_dot_kkt_dtype_layout_generalization",
      "chunk_scaled_dot_kkt_tail_or_varlen"
    ],
    "generalization_case_ids": [
      "chunk_scaled_dot_kkt_dtype_layout_generalization",
      "chunk_scaled_dot_kkt_tail_or_varlen"
    ],
    "negative_case_ids": [
      "chunk_scaled_dot_kkt_negative_contract",
      "chunk_scaled_dot_kkt_varlen_requires_b1",
      "chunk_scaled_dot_kkt_varlen_pair_required"
    ],
    "route_case_ids": [
      "chunk_scaled_dot_kkt_main_accuracy",
      "chunk_scaled_dot_kkt_performance"
    ],
    "performance_case_ids": [
      "chunk_scaled_dot_kkt_performance"
    ],
    "legacy_regression_case_ids": [
      "legacy_python_backend_cases_0000",
      "legacy_python_backend_cases_0001",
