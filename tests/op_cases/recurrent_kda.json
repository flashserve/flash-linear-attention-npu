{
  "schema_version": 1,
  "op": "recurrent_kda",
  "implementation": "ascendc",
  "model": "kda",
  "symbol_table_version": "kda-shape-v1",
  "capability": {
    "soc": [
      "ascend910b",
      "ascend910_93",
      "ascend950"
    ],
    "dtypes": [
      "bfloat16",
      "float16",
      "float32"
    ],
    "layouts": [
      "BSND",
      "TND"
    ],
    "features": [
      "定长/变长序列",
      "raw gate 与预计算 log gate",
      "safe_gate lower_bound clamp",
      "beta sigmoid",
      "可选初始/最终状态",
      "state_v_first=True"
    ],
    "routes": [
      "ascendc",
      "aclnn",
      "direct_launch"
    ],
    "optional_routes": [
      "torch_ops_npu"
    ]
  },
  "data_generation": {
    "floating_inputs": {
      "distribution": "normal",
      "mean": 0.0,
      "std": 0.5
    },
    "structured_inputs": "由 tests/reference/recurrent_kda_reference.py 构造 q/k/v、raw gate、beta、初始状态和变长索引"
  },
  "coverage_requirements": {
    "public_modes": [
      "fused recurrent 单 kernel",
      "raw gate: gate + dt_bias -> safe/unsafe log gate",
      "预计算 log gate",
      "beta sigmoid 与 allow_neg_eigval",
      "BSND/TND",
      "初始状态为空或显式传入"
    ],
    "known_limits": [
      "q/k/v 当前支持 bfloat16；g/beta 支持 float32/bfloat16/float16，A_log 与 dt_bias 必须为 float32。",
      "layout 当前仅支持 BSND 和 TND；H_v 必须能被 H 整除。",
      "K/V 当前仅支持 K=128,V=128 或 K=128,V=256 两档枚举。",
      "每条 recurrent 序列长度当前必须 <= 8；BSND 变长序列物理 B 必须为 1。",
      "state_v_first 当前必须为 true，状态布局为 [seq_num,H_v,V,K]。",
      "use_gate_in_kernel=true 时 A_log 必传；dt_bias 若存在须为 [H_v*K] 或 [H_v,K]。",
      "use_gate_in_kernel=false 时 A_log、dt_bias 和 safe_gate 必须为空或 false，避免两段式 gate 语义混入 recurrent API。",
      "num_accepted_tokens 需要和 ssm_state_indices 一起传入，长度为 seq_num。"
    ],
    "required_outputs": [
      "out",
      "final_state"
    ],
    "accuracy_case_ids": [
      "recurrent_kda_bsnd_raw_gate_accuracy",
      "recurrent_kda_bsnd_safe_gate_beta_sigmoid",
      "recurrent_kda_tnd_precomputed_gate_zero_state",
      "recurrent_kda_kimi_bsnd_gva_k128_v128",
      "recurrent_kda_kimi_tnd_safe_gate_v256",
      "recurrent_kda_bsnd_precomputed_output_only_bf16_gate",
      "recurrent_kda_bsnd_varlen_precomputed_zero_segment",
      "recurrent_kda_tnd_raw_gate_no_dt_bias_no_beta_sigmoid",
      "recurrent_kda_tnd_ssm_accepted_flat_dt_bias_fp16_gate",
      "recurrent_kda_tnd_precomputed_v256_general"
    ],
    "generalization_case_ids": [
      "recurrent_kda_bsnd_safe_gate_beta_sigmoid",
      "recurrent_kda_tnd_precomputed_gate_zero_state",
      "recurrent_kda_kimi_bsnd_gva_k128_v128",
      "recurrent_kda_kimi_tnd_safe_gate_v256",
      "recurrent_kda_bsnd_precomputed_output_only_bf16_gate",
      "recurrent_kda_bsnd_varlen_precomputed_zero_segment",
      "recurrent_kda_tnd_raw_gate_no_dt_bias_no_beta_sigmoid",
      "recurrent_kda_tnd_ssm_accepted_flat_dt_bias_fp16_gate",
      "recurrent_kda_tnd_precomputed_v256_general",
      "recurrent_kda_kimi_tnd_h96_d128_runtime_cu_smoke"
    ],
    "stress_case_ids": [
      "recurrent_kda_kimi_tnd_long_safe_gate_h96_d128"
    ],
    "negative_case_ids": [
      "recurrent_kda_negative_contract"
    ],
    "route_case_ids": [
      "recurrent_kda_bsnd_raw_gate_accuracy",
      "recurrent_kda_tnd_precomputed_gate_zero_state"
    ]
  },
  "tolerance": {
    "bfloat16": {
      "rtol": 0.02,
      "atol": 0.01
    },
    "float32": {
      "rtol": 0.002,
      "atol": 0.002
    }
  },
