{
  "schema_version": 1,
  "op": "chunk_local_cumsum",
  "implementation": "ascendc",
  "model": "gdn",
  "symbol_table_version": "gdn-shape-v1",
  "capability": {
    "soc": [
      "ascend910b",
      "ascend910_93",
      "ascend950"
    ],
    "dtypes": [
      "float32",
      "int64"
    ],
    "layouts": [
      "BNS"
    ],
    "features": [
      "fixed/varlen",
      "forward/reverse",
      "任意连续尾部 P"
    ],
    "routes": [
      "ascendc",
      "aclnn",
      "direct_launch"
    ],
    "optional_routes": [
      "torch_ops_npu"
    ]
  },
  "data_generation": {
    "floating_inputs": {
      "distribution": "uniform",
      "min": -1.0,
      "max": 1.0
    },
    "positive_inputs": {
      "distribution": "uniform",
      "min": 0.0,
      "max": 1.0
    },
    "structured_inputs": "由 reference 名称对应的 runner 构造 gate、三角矩阵、状态和索引"
  },
  "coverage_requirements": {
    "public_modes": [
      "fixed/varlen",
      "forward/reverse",
      "任意连续尾部 P"
    ],
    "known_limits": [
      "g rank 至少 3，所有维度为正；head_first 当前必须 true。",
      "chunk_size 必须为 2 的幂且满足 B_T >= C；交付矩阵至少覆盖 P=1,C=64 的 varlen 尾块和 P=16,C=64 的 dense 尾块。",
      "output_dtype 仅支持 FP32 别名。",
      "varlen 物理 B=1，两个 host 整数数组必须同时提供；cu_seqlens 首项为 0、末项为 T 且非递减。",
      "chunk_indices_out 必须按 sequence-major 完整列出内部处理块；处理块长度 B_T 由 UB、C 和 P 共同决定，不能直接按 C 构造。"
    ],
    "required_outputs": [
      "out"
    ],
    "accuracy_case_ids": [
      "chunk_local_cumsum_main_accuracy",
      "chunk_local_cumsum_dtype_layout_generalization",
      "chunk_local_cumsum_tail_or_varlen"
    ],
    "generalization_case_ids": [
      "chunk_local_cumsum_dtype_layout_generalization",
      "chunk_local_cumsum_tail_or_varlen"
    ],
    "negative_case_ids": [
      "chunk_local_cumsum_negative_contract",
      "chunk_local_cumsum_varlen_pair_required",
      "chunk_local_cumsum_invalid_dtype",
      "chunk_local_cumsum_non_power_of_two",
      "chunk_local_cumsum_varlen_requires_b1",
      "chunk_local_cumsum_invalid_block_order"
    ],
    "route_case_ids": [
      "chunk_local_cumsum_main_accuracy",
      "chunk_local_cumsum_performance"
    ],
    "performance_case_ids": [
      "chunk_local_cumsum_performance"
    ]
  },
  "tolerance": {
    "float16": {
      "rtol": 0.003,
      "atol": 0.003
    },
    "bfloat16": {
      "rtol": 0.006,
      "atol": 0.006
    }
  },
