{
  "schema_version": 1,
  "op": "chunk_fwd_o",
  "implementation": "ascendc",
  "model": "gdn",
  "symbol_table_version": "gdn-shape-v1",
  "capability": {
    "soc": [
      "ascend910b",
      "ascend910_93",
      "ascend950"
    ],
    "dtypes": [
      "bfloat16",
      "float16",
      "float32"
    ],
    "layouts": [
      "BNSD"
    ],
    "features": [
      "定长/变长序列",
      "GVA",
      "整块/尾块",
      "g 为必选标量 gate"
    ],
    "routes": [
      "ascendc",
      "aclnn",
      "direct_launch"
    ],
    "optional_routes": [
      "torch_ops_npu"
    ]
  },
  "data_generation": {
    "floating_inputs": {
      "distribution": "normal",
      "std": 0.1,
      "inputs": [
        "q",
        "k",
        "v",
        "h"
      ]
    },
    "structured_inputs": "g 在 [-0.25, 0.25] 上按 T 线性生成；变长序列索引按 sequence-major 构造。该生成规则与仓内 direct-launch 精度用例一致。"
  },
  "coverage_requirements": {
    "public_modes": [
      "定长/变长序列",
      "GVA",
      "整块/尾块",
      "g 为必选标量 gate"
    ],
    "known_limits": [
      "`K` 仅支持 128，`V` 仅支持 128/256，`chunk_size` 仅支持 64/128。",
      "必须满足 `H_v % H_k == 0`，h 的 chunk 数必须与索引推导一致。",
      "变长序列当前仅支持物理 `B=1`，两个索引必须同时提供。",
      "`g` 是 kernel 必选输入；`g_gamma` 必须为 None，`transpose_state_layout` 必须为 false。"
    ],
    "required_outputs": [
      "o"
    ],
    "accuracy_case_ids": [
      "chunk_fwd_o_main_accuracy",
      "chunk_fwd_o_dtype_layout_generalization",
      "chunk_fwd_o_tail_or_varlen"
    ],
    "generalization_case_ids": [
      "chunk_fwd_o_dtype_layout_generalization",
      "chunk_fwd_o_tail_or_varlen"
    ],
    "negative_case_ids": [
      "chunk_fwd_o_negative_contract",
      "chunk_fwd_o_missing_gate",
      "chunk_fwd_o_varlen_pair_required",
      "chunk_fwd_o_invalid_feature_dim",
      "chunk_fwd_o_invalid_h_chunk_count",
      "chunk_fwd_o_invalid_chunk_order"
    ],
    "route_case_ids": [
      "chunk_fwd_o_main_accuracy",
      "chunk_fwd_o_performance"
    ],
    "performance_case_ids": [
      "chunk_fwd_o_performance"
    ],
    "legacy_regression_case_ids": [
      "legacy_fast_kernel_fixed_0000",
      "legacy_fast_kernel_fixed_0001",
      "legacy_fast_kernel_fixed_0002",
      "legacy_fast_kernel_fixed_0003",
      "legacy_fast_kernel_variable_0000",
      "legacy_fast_kernel_variable_0001",
      "legacy_fast_kernel_variable_0002",
      "legacy_fast_kernel_variable_0003"
    ]
  },
  "tolerance": {
    "float16": {
      "rtol": 0.02,
      "atol": 0.02
    },
    "bfloat16": {
      "rtol": 0.02,
      "atol": 0.02
    }
  },
  "accuracy_policy": {
    "method": "torch_allclose",
    "basis": "tests/operators/chunk_fwd_o/routes/test_fast_kernel_chunk_fwd_o.py",
    "description": "沿用仓内 direct-launch 数值测试对多段 Cube、Exp 与中间 dtype 转换的既有 2e-2 标准。"
  },
