{
  "schema_version": 1,
  "op": "solve_tri",
  "implementation": "ascendc",
  "model": "gdn",
  "symbol_table_version": "gdn-shape-v1",
  "capability": {
    "soc": [
      "ascend910b",
      "ascend910_93",
      "ascend950"
    ],
    "dtypes": [
      "bfloat16",
      "float16"
    ],
    "layouts": [
      "bhtd",
      "bsnd",
      "tnd"
    ],
    "features": [
      "dense BHTD/BSND",
      "varlen TND",
      "支持尾块"
    ],
    "routes": [
      "ascendc",
      "aclnn",
      "direct_launch"
    ],
    "optional_routes": [
      "torch_ops_npu"
    ]
  },
  "data_generation": {
    "floating_inputs": {
      "distribution": "uniform",
      "min": -1.0,
      "max": 1.0
    },
    "positive_inputs": {
      "distribution": "uniform",
      "min": 0.0,
      "max": 1.0
    },
    "structured_inputs": "由 reference 名称对应的 runner 构造 gate、三角矩阵、状态和索引"
  },
  "coverage_requirements": {
    "public_modes": [
      "dense BHTD/BSND",
      "varlen TND",
      "支持尾块"
    ],
    "known_limits": [
      "矩阵阶/最后一维 C 支持 16/32/64/128。",
      "layout 仅支持小写 `bhtd`、`bsnd`、`tnd`；TND 必须提供两个 varlen 索引，dense layout 不接受 varlen 索引。",
      "输入必须表示严格下三角 A；对角线由算子加单位阵。"
    ],
    "required_outputs": [
      "x_out"
    ],
    "accuracy_case_ids": [
      "solve_tri_main_accuracy",
      "solve_tri_dtype_layout_generalization",
      "solve_tri_tail_or_varlen",
      "solve_tri_c16_boundary"
