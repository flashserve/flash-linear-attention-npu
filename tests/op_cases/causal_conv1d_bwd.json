{
  "schema_version": 1,
  "op": "causal_conv1d_bwd",
  "implementation": "ascendc",
  "model": "gdn",
  "symbol_table_version": "gdn-shape-v1",
  "capability": {
    "soc": [
      "ascend910b",
      "ascend910_93",
      "ascend950"
    ],
    "dtypes": [
      "bfloat16",
      "float16",
      "int64"
    ],
    "layouts": [
      "BNSD",
      "BSH",
      "NTD"
    ],
    "features": [
      "dense/varlen",
      "无激活/SiLU",
      "可选初末状态"
    ],
    "routes": [
      "ascendc",
      "aclnn",
      "direct_launch"
    ],
    "optional_routes": [
      "torch_ops_npu"
    ]
  },
  "data_generation": {
    "floating_inputs": {
      "distribution": "uniform",
      "min": -1.0,
      "max": 1.0
    },
    "positive_inputs": {
      "distribution": "uniform",
      "min": 0.0,
      "max": 1.0
    },
    "structured_inputs": "由 reference 名称对应的 runner 构造 gate、三角矩阵、状态和索引"
  },
  "coverage_requirements": {
    "public_modes": [
      "dense/varlen",
      "无激活/SiLU",
      "可选初末状态"
    ],
    "known_limits": [
      "weight 必须 `[W,D]` 且 W 仅支持 2/3/4；D 或拆分后的 V 必须为 16 的倍数。",
      "activation=1/2 时 y 必须提供且与 dy 同 layout/shape。",
      "TND/NTD 必须提供合法 query_start_loc；累计长度非递减、首项为 0、末项为总 T，且总 token 数必须大于 0。",
      "initial_state/dht/dh0 的逻辑 shape 为 `[B,W,D]`。"
    ],
    "required_outputs": [
      "dx",
      "dw",
      "db",
      "dh0"
    ],
    "accuracy_case_ids": [
      "causal_conv1d_bwd_main_accuracy",
      "causal_conv1d_bwd_dtype_layout_generalization",
      "causal_conv1d_bwd_tail_or_varlen"
    ],
    "negative_case_ids": [
      "causal_conv1d_bwd_negative_contract",
      "causal_conv1d_bwd_invalid_width",
      "causal_conv1d_bwd_varlen_requires_offsets",
      "causal_conv1d_bwd_invalid_state_shape"
    ],
    "route_case_ids": [
      "causal_conv1d_bwd_main_accuracy",
      "causal_conv1d_bwd_performance"
    ],
    "performance_case_ids": [
      "causal_conv1d_bwd_performance"
    ]
  },
  "tolerance": {
    "float16": {
      "rtol": 0.003,
      "atol": 0.003
    },
    "bfloat16": {
      "rtol": 0.006,
      "atol": 0.006
    }
  },
  "cases": [
    {
