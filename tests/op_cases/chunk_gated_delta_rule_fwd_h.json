    ],
    "features": [
      "fixed/varlen",
      "g/gk",
      "可选 initial/final state"
    ],
    "routes": [
      "ascendc",
      "aclnn",
      "direct_launch"
    ],
    "optional_routes": [
      "torch_ops_npu"
    ]
  },
  "data_generation": {
    "floating_inputs": {
      "distribution": "model_derived",
      "inputs": [
        "k",
        "w",
        "u",
        "initial_state"
      ]
    },
    "structured_inputs": "k 做 L2 normalize；g 由 logsigmoid 增量在每个 chunk 内 cumsum；W/U 按 A=I 的 GDN WY 公式由 k/value/beta/g 推导；varlen 索引按 sequence-major 构造。"
  },
  "accuracy_policy": {
    "method": "element_error_ratio",
    "max_fail_ratio": 0.05,
    "max_relative_error": 0.1,
    "description": "绝对误差小于 dtype atol 时按绝对误差计，其余元素按相对误差计；判据与仓内 direct-launch 精度测试一致。"
  },
  "coverage_requirements": {
    "public_modes": [
      "fixed/varlen",
      "g/gk",
      "可选 initial/final state"
    ],
    "known_limits": [
      "`K` 仅支持 128，`V` 仅支持 128/256，`chunk_size` 仅支持 64/128。",
      "`g` 与 `gk` 至少提供一个；`H_v % H_k == 0`。",
      "varlen 当前仅支持物理 `B=1`，索引必须完整且 sequence-major。",
      "`save_new_value=true`、`use_exp2=false`、`transpose_state_layout=false`。"
    ],
    "required_outputs": [
      "h",
      "v_new",
      "final_state"
    ],
    "accuracy_case_ids": [
      "chunk_gated_delta_rule_fwd_h_main_accuracy",
