<?xml version="1.0" encoding="UTF-8"?>
<mxfile host="Electron" modified="2026-07-17T20:00:00.000Z" agent="Codex" version="26.0.16" type="device">
  <diagram id="dv-normal-deadlock" name="正常与卡死流水">
    <mxGraphModel dx="1800" dy="1300" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1800" pageHeight="1300" background="#FFFFFF" math="0" shadow="0">
      <root>
        <mxCell id="0"/>
        <mxCell id="1" parent="0"/>

        <mxCell id="title" value="ChunkBwdDvLocal：预期正常流水与旧协议卡死流水" style="text;html=0;align=center;verticalAlign=middle;fontSize=28;fontStyle=1;fontColor=#17202A;whiteSpace=wrap;" vertex="1" parent="1">
          <mxGeometry x="100" y="20" width="1600" height="45" as="geometry"/>
        </mxCell>
        <mxCell id="layout" value="真实数据流：Cube 计算 K @ Qᵀ → Vector 执行 gate/mask/scale → Cube 计算 gated(KQᵀ) @ dO → dV_local&#xa;当前 shape：3 个逻辑 slot 组；QK block 0..2，GATED block 3..5；s = qkHead % 3" style="rounded=1;arcSize=5;whiteSpace=wrap;html=0;fillColor=#F4F6F7;strokeColor=#5D6D7E;strokeWidth=1.5;fontColor=#273746;fontSize=16;fontStyle=1;align=center;verticalAlign=middle;" vertex="1" parent="1">
          <mxGeometry x="250" y="80" width="1300" height="100" as="geometry"/>
        </mxCell>

        <mxCell id="normalBg" value="" style="rounded=1;arcSize=4;whiteSpace=wrap;html=0;fillColor=#FFFFFF;strokeColor=#148F77;strokeWidth=2;" vertex="1" parent="1">
          <mxGeometry x="50" y="220" width="820" height="850" as="geometry"/>
        </mxCell>
        <mxCell id="normalTitle" value="A. 预期正确：payload 所有权闭环 + flag 反向窗口闭环" style="rounded=1;arcSize=5;whiteSpace=wrap;html=0;fillColor=#E8F8F5;strokeColor=#148F77;strokeWidth=2;fontColor=#0E6251;fontSize=18;fontStyle=1;align=center;verticalAlign=middle;" vertex="1" parent="1">
          <mxGeometry x="80" y="245" width="760" height="54" as="geometry"/>
        </mxCell>
        <mxCell id="n1" value="① AIC / Cube&#xa;Wait QK_FREE[s] → K @ Qᵀ → 写 QK[s] → WriteDone" style="rounded=1;arcSize=5;whiteSpace=wrap;html=0;fillColor=#D6EAF8;strokeColor=#2874A6;fontColor=#1B4F72;fontSize=15;fontStyle=1;align=center;verticalAlign=middle;" vertex="1" parent="1"><mxGeometry x="120" y="330" width="680" height="70" as="geometry"/></mxCell>
        <mxCell id="n2" value="SET QK_READY&#xa;第 Depth 次 SET 后，AIC WAIT QK_REVERSE_ACK" style="shape=hexagon;perimeter=hexagonPerimeter2;whiteSpace=wrap;html=0;fillColor=#EBF5FB;strokeColor=#2874A6;fontColor=#1B4F72;fontSize=14;fontStyle=1;align=center;verticalAlign=middle;" vertex="1" parent="1"><mxGeometry x="240" y="430" width="440" height="62" as="geometry"/></mxCell>
        <mxCell id="n3" value="② AIV / Vector&#xa;WAIT QK_READY + Wait GATED_FREE[s]&#xa;读 QK[s] → gate/mask/scale → 写 GATED[s]" style="rounded=1;arcSize=5;whiteSpace=wrap;html=0;fillColor=#FCF3CF;strokeColor=#B7950B;fontColor=#7D6608;fontSize=14;fontStyle=1;align=center;verticalAlign=middle;" vertex="1" parent="1"><mxGeometry x="120" y="525" width="680" height="82" as="geometry"/></mxCell>
        <mxCell id="n4" value="LastAsyncReadDone(QK[s]) → SET QK_FREE[s]&#xa;WriteDone(GATED[s]) → SET GATED_READY" style="rounded=1;arcSize=5;whiteSpace=wrap;html=0;fillColor=#E8F8F5;strokeColor=#148F77;fontColor=#0E6251;fontSize=14;fontStyle=1;align=center;verticalAlign=middle;" vertex="1" parent="1"><mxGeometry x="160" y="640" width="600" height="72" as="geometry"/></mxCell>
        <mxCell id="n5" value="③ AIC / Cube&#xa;WAIT GATED_READY → 读 GATED[s]&#xa;gated(KQᵀ) @ dO → dV" style="rounded=1;arcSize=5;whiteSpace=wrap;html=0;fillColor=#D5F5E3;strokeColor=#148F77;fontColor=#0E6251;fontSize=14;fontStyle=1;align=center;verticalAlign=middle;" vertex="1" parent="1"><mxGeometry x="120" y="745" width="680" height="82" as="geometry"/></mxCell>
        <mxCell id="n6" value="LastAsyncReadDone(GATED[s]) → SET GATED_FREE[s]&#xa;下一 head 使用 (s + 1) % 3；回到 s 前必须拿到 FREE" style="rounded=1;arcSize=5;whiteSpace=wrap;html=0;fillColor=#E8F8F5;strokeColor=#148F77;fontColor=#0E6251;fontSize=14;fontStyle=1;align=center;verticalAlign=middle;" vertex="1" parent="1"><mxGeometry x="140" y="860" width="640" height="72" as="geometry"/></mxCell>
        <mxCell id="n7" value="独立的 flag 窗口&#xa;SET #1...#15 → AIC WAIT reverseId&#xa;AIV 第 15 次 WAIT 后 SET reverseId → count 清零，继续 #16" style="rounded=1;arcSize=5;whiteSpace=wrap;html=0;fillColor=#EBF5FB;strokeColor=#2874A6;fontColor=#1B4F72;fontSize=14;fontStyle=1;align=center;verticalAlign=middle;" vertex="1" parent="1"><mxGeometry x="120" y="960" width="680" height="82" as="geometry"/></mxCell>

        <mxCell id="deadBg" value="" style="rounded=1;arcSize=4;whiteSpace=wrap;html=0;fillColor=#FFFFFF;strokeColor=#C0392B;strokeWidth=2;" vertex="1" parent="1">
          <mxGeometry x="930" y="220" width="820" height="850" as="geometry"/>
        </mxCell>
        <mxCell id="deadTitle" value="B. 旧 QK 协议：3-slot 已约束 outstanding；精确设备卡点仍需定位" style="rounded=1;arcSize=5;whiteSpace=wrap;html=0;fillColor=#FDEDEC;strokeColor=#C0392B;strokeWidth=2;fontColor=#922B21;fontSize=18;fontStyle=1;align=center;verticalAlign=middle;" vertex="1" parent="1">
          <mxGeometry x="960" y="245" width="760" height="54" as="geometry"/>
        </mxCell>
        <mxCell id="d1" value="AIC 仍按 slot 0 → 1 → 2 → 0 轮转&#xa;连续计算 32 个 head 的 K @ Qᵀ" style="rounded=1;arcSize=5;whiteSpace=wrap;html=0;fillColor=#D6EAF8;strokeColor=#2874A6;fontColor=#1B4F72;fontSize=15;fontStyle=1;align=center;verticalAlign=middle;" vertex="1" parent="1"><mxGeometry x="1000" y="330" width="680" height="70" as="geometry"/></mxCell>
        <mxCell id="d2" value="官方 counter 语义&#xa;AIC SET：counter +1；AIV WAIT：counter -1；最大值 15" style="rounded=1;arcSize=5;whiteSpace=wrap;html=0;fillColor=#FDEDEC;strokeColor=#C0392B;fontColor=#922B21;fontSize=15;fontStyle=1;align=center;verticalAlign=middle;" vertex="1" parent="1"><mxGeometry x="1020" y="425" width="640" height="70" as="geometry"/></mxCell>
        <mxCell id="d3" value="代码级 slot 证明&#xa;SET QK[h] 前先 WAIT GATED[h-3]&#xa;这蕴含 AIV 已 WAIT QK[h-3]" style="rounded=1;arcSize=5;whiteSpace=wrap;html=0;fillColor=#FEF9E7;strokeColor=#B7950B;fontColor=#7D6608;fontSize=15;fontStyle=1;align=center;verticalAlign=middle;" vertex="1" parent="1"><mxGeometry x="1000" y="510" width="680" height="82" as="geometry"/></mxCell>
        <mxCell id="d4" value="h=15（第 16 次总 SET）时&#xa;累计 WAIT 至少为 13，hardware outstanding ≤ 3" style="rounded=1;arcSize=5;whiteSpace=wrap;html=0;fillColor=#D5F5E3;strokeColor=#148F77;fontColor=#0E6251;fontSize=15;fontStyle=1;align=center;verticalAlign=middle;" vertex="1" parent="1"><mxGeometry x="1000" y="620" width="680" height="76" as="geometry"/></mxCell>
        <mxCell id="d5" value="因此不能解释成 hardware counter 单纯累到 15 后永久卡死&#xa;wrapper flag.count 统计的是总调用数，不是 outstanding counter" style="rounded=1;arcSize=5;whiteSpace=wrap;html=0;fillColor=#FDEDEC;strokeColor=#C0392B;strokeWidth=2;fontColor=#922B21;fontSize=14;fontStyle=1;align=center;verticalAlign=middle;" vertex="1" parent="1"><mxGeometry x="1000" y="725" width="680" height="84" as="geometry"/></mxCell>
        <mxCell id="d6" value="仍待验证&#xa;PIPE_FIX/MTE2 在途顺序｜同 flagId 单向重复使用约束&#xa;reverse 改变时序后掩盖其它竞态" style="rounded=1;arcSize=5;whiteSpace=wrap;html=0;fillColor=#FDEDEC;strokeColor=#C0392B;strokeWidth=2;fontColor=#922B21;fontSize=14;fontStyle=1;align=center;verticalAlign=middle;" vertex="1" parent="1"><mxGeometry x="1000" y="840" width="680" height="90" as="geometry"/></mxCell>
        <mxCell id="d7" value="没有设备 PC、pipe 在途状态和 flag 快照，精确卡点尚未确认" style="rounded=1;arcSize=5;whiteSpace=wrap;html=0;fillColor=#922B21;strokeColor=#641E16;fontColor=#FFFFFF;fontSize=15;fontStyle=1;align=center;verticalAlign=middle;" vertex="1" parent="1"><mxGeometry x="1000" y="980" width="680" height="54" as="geometry"/></mxCell>

        <mxCell id="bottom" value="slot 环深度=3：payload 最大在途距离｜wrapper flag.count=总调用数：到15做reverse｜hardware counter=SET-WAIT：顺序模型下≤3&#xa;第16次总SET可以在slot反复释放和复用后发生；它与“同时有16个未消费SET”不是一回事。" style="rounded=1;arcSize=5;whiteSpace=wrap;html=0;fillColor=#F4ECF7;strokeColor=#7D3C98;strokeWidth=2;fontColor=#512E5F;fontSize=16;fontStyle=1;align=center;verticalAlign=middle;" vertex="1" parent="1">
          <mxGeometry x="250" y="1120" width="1300" height="100" as="geometry"/>
        </mxCell>

        <mxCell id="ne1" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=0;strokeColor=#148F77;strokeWidth=2;endArrow=block;endFill=1;" edge="1" parent="1" source="n1" target="n2"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="ne2" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=0;strokeColor=#148F77;strokeWidth=2;endArrow=block;endFill=1;" edge="1" parent="1" source="n2" target="n3"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="ne3" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=0;strokeColor=#148F77;strokeWidth=2;endArrow=block;endFill=1;" edge="1" parent="1" source="n3" target="n4"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="ne4" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=0;strokeColor=#148F77;strokeWidth=2;endArrow=block;endFill=1;" edge="1" parent="1" source="n4" target="n5"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="ne5" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=0;strokeColor=#148F77;strokeWidth=2;endArrow=block;endFill=1;" edge="1" parent="1" source="n5" target="n6"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="ne6" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=0;strokeColor=#2874A6;strokeWidth=2;endArrow=block;endFill=1;" edge="1" parent="1" source="n6" target="n7"><mxGeometry relative="1" as="geometry"/></mxCell>
