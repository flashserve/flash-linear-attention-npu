<mxfile host="Electron" modified="2026-07-14T14:40:00.000Z" agent="Codex" version="24.7.17">
  <diagram id="dependency-lifecycle" name="依赖确定阶段">
    <mxGraphModel dx="1500" dy="930" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1500" pageHeight="930" math="0" shadow="0">
      <root>
        <mxCell id="0"/>
        <mxCell id="1" parent="0"/>

        <mxCell id="title" value="&lt;b&gt;新架构的依赖在什么时候确定&lt;/b&gt;" style="text;html=1;align=center;verticalAlign=middle;whiteSpace=wrap;fontSize=25;fontColor=#172033;" vertex="1" parent="1">
          <mxGeometry x="250" y="25" width="1000" height="45" as="geometry"/>
        </mxCell>
        <mxCell id="subtitle" value="框架版本留在目标环境；CANN、SOC、host 二进制留在构建产物" style="text;html=1;align=center;verticalAlign=middle;whiteSpace=wrap;fontSize=15;fontColor=#52606D;" vertex="1" parent="1">
          <mxGeometry x="300" y="72" width="900" height="30" as="geometry"/>
        </mxCell>

        <mxCell id="build" value="&lt;b&gt;1  OPP 构建&lt;/b&gt;&lt;br/&gt;&lt;br/&gt;&lt;b&gt;此时固定&lt;/b&gt;&lt;br/&gt;CANN 头文件与工具链&lt;br/&gt;FLA_NPU_SOC&lt;br/&gt;host 架构&lt;br/&gt;gcc / libstdc++ 基线&lt;br/&gt;&lt;br/&gt;&lt;b&gt;此时不读取&lt;/b&gt;&lt;br/&gt;torch / torch_npu ABI" style="rounded=1;arcSize=7;whiteSpace=wrap;html=1;fillColor=#EEF4FF;strokeColor=#5B7DB1;strokeWidth=2;fontSize=14;fontColor=#172033;spacing=9;" vertex="1" parent="1">
          <mxGeometry x="30" y="150" width="250" height="350" as="geometry"/>
        </mxCell>
        <mxCell id="wheel" value="&lt;b&gt;2  wheel 组装&lt;/b&gt;&lt;br/&gt;&lt;br/&gt;&lt;b&gt;写入产物&lt;/b&gt;&lt;br/&gt;公开版本与源码标识&lt;br/&gt;SOC.host build tag&lt;br/&gt;Python wrapper&lt;br/&gt;完整 OPP vendor 树&lt;br/&gt;&lt;br/&gt;&lt;b&gt;不锁定&lt;/b&gt;&lt;br/&gt;Python minor / torch / Triton" style="rounded=1;arcSize=7;whiteSpace=wrap;html=1;fillColor=#EEF4FF;strokeColor=#5B7DB1;strokeWidth=2;fontSize=14;fontColor=#172033;spacing=9;" vertex="1" parent="1">
          <mxGeometry x="325" y="150" width="250" height="350" as="geometry"/>
        </mxCell>
        <mxCell id="install" value="&lt;b&gt;3  pip 安装&lt;/b&gt;&lt;br/&gt;&lt;br/&gt;&lt;b&gt;安装门禁&lt;/b&gt;&lt;br/&gt;python_requires &amp;gt;= 3.9&lt;br/&gt;普通 Python 依赖&lt;br/&gt;&lt;br/&gt;&lt;b&gt;pip 不检查&lt;/b&gt;&lt;br/&gt;build tag 中的 SOC / 架构&lt;br/&gt;CANN runtime&lt;br/&gt;torch 与 torch_npu 配套关系" style="rounded=1;arcSize=7;whiteSpace=wrap;html=1;fillColor=#EFF9F1;strokeColor=#4C9B60;strokeWidth=2;fontSize=14;fontColor=#172033;spacing=9;" vertex="1" parent="1">
          <mxGeometry x="620" y="150" width="250" height="350" as="geometry"/>
        </mxCell>
        <mxCell id="import" value="&lt;b&gt;4  import / dlopen&lt;/b&gt;&lt;br/&gt;&lt;br/&gt;&lt;b&gt;运行时选择&lt;/b&gt;&lt;br/&gt;已 source 的 CANN&lt;br/&gt;内嵌或显式外部 OPP&lt;br/&gt;libcust_opapi.so&lt;br/&gt;&lt;br/&gt;&lt;b&gt;RTLD_NOW 检查&lt;/b&gt;&lt;br/&gt;ELF 架构、依赖库&lt;br/&gt;必需动态符号" style="rounded=1;arcSize=7;whiteSpace=wrap;html=1;fillColor=#FFF7E8;strokeColor=#D9970B;strokeWidth=2;fontSize=14;fontColor=#172033;spacing=9;" vertex="1" parent="1">
          <mxGeometry x="915" y="150" width="250" height="350" as="geometry"/>
        </mxCell>
        <mxCell id="call" value="&lt;b&gt;5  首次算子调用&lt;/b&gt;&lt;br/&gt;&lt;br/&gt;&lt;b&gt;从当前环境取得&lt;/b&gt;&lt;br/&gt;torch Python tensor API&lt;br/&gt;NPU device / dtype / storage&lt;br/&gt;shape / stride / data pointer&lt;br/&gt;current NPU stream&lt;br/&gt;可选真实 ACL format&lt;br/&gt;&lt;br/&gt;&lt;b&gt;按能力调用，不比对构建机 torch&lt;/b&gt;" style="rounded=1;arcSize=7;whiteSpace=wrap;html=1;fillColor=#F4F0FF;strokeColor=#8266B5;strokeWidth=2;fontSize=14;fontColor=#172033;spacing=9;" vertex="1" parent="1">
          <mxGeometry x="1210" y="150" width="250" height="350" as="geometry"/>
        </mxCell>

        <mxCell id="fixed" value="&lt;b&gt;构建产物已经固定&lt;/b&gt;&lt;br/&gt;CANN 编译接口 × SOC kernel × host ELF × 工具链基线&lt;br/&gt;这些依赖不能因 py3-none-any 命名而被忽略" style="rounded=1;arcSize=7;whiteSpace=wrap;html=1;fillColor=#EEF4FF;strokeColor=#5B7DB1;strokeWidth=2;fontSize=15;fontColor=#24466F;spacing=9;" vertex="1" parent="1">
          <mxGeometry x="30" y="575" width="545" height="120" as="geometry"/>
        </mxCell>
        <mxCell id="runtime" value="&lt;b&gt;目标环境运行时确定&lt;/b&gt;&lt;br/&gt;Python × torch × torch_npu 后端 × Triton × CANN runtime&lt;br/&gt;fla_npu 不冻结框架 ABI，但要求当前环境提供所需能力" style="rounded=1;arcSize=7;whiteSpace=wrap;html=1;fillColor=#F4F0FF;strokeColor=#8266B5;strokeWidth=2;fontSize=15;fontColor=#49366B;spacing=9;" vertex="1" parent="1">
          <mxGeometry x="620" y="575" width="840" height="120" as="geometry"/>
        </mxCell>
        <mxCell id="matrix" value="&lt;b&gt;CI / 发布矩阵给出真实兼容范围&lt;/b&gt;&lt;br/&gt;验证 import、动态符号、stream、单算子精度和端到端 Example/ST&lt;br/&gt;结论是“这些组合经过验证”，不是“pip 已自动保证所有组合”" style="rounded=1;arcSize=7;whiteSpace=wrap;html=1;fillColor=#E9F7EE;strokeColor=#4C9B60;strokeWidth=2.5;fontSize=16;fontColor=#244B2F;spacing=10;" vertex="1" parent="1">
          <mxGeometry x="180" y="765" width="1140" height="120" as="geometry"/>
        </mxCell>

        <mxCell id="e1" value="" style="edgeStyle=none;rounded=0;html=1;endArrow=block;endFill=1;strokeWidth=2.4;strokeColor=#52606D;exitX=1;exitY=0.5;entryX=0;entryY=0.5;" edge="1" parent="1" source="build" target="wheel"><mxGeometry relative="1" as="geometry"/></mxCell>
