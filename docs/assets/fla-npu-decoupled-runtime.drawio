        <mxCell id="wheel" value="&lt;b&gt;py3-none-any wheel&lt;/b&gt;&lt;br/&gt;Python wrapper + 内嵌 OPP&lt;br/&gt;不携带 cp / cxx11abi tag" style="rounded=1;arcSize=8;whiteSpace=wrap;html=1;fillColor=#F4F8FF;strokeColor=#5B7DB1;strokeWidth=2;fontSize=15;fontColor=#172033;spacing=8;" vertex="1" parent="1">
