        <mxCell id="blue-panel" value="" style="rounded=1;arcSize=5;whiteSpace=wrap;html=1;fillColor=#F5F9FF;strokeColor=#AFC4E8;strokeWidth=1.5;" vertex="1" parent="1"><mxGeometry x="1030" y="120" width="440" height="610" as="geometry"/></mxCell>

        <mxCell id="green-header" value="&lt;b&gt;当前已有硬门禁&lt;/b&gt;" style="rounded=1;arcSize=7;whiteSpace=wrap;html=1;fillColor=#E9F7EE;strokeColor=#4C9B60;strokeWidth=2;fontSize=18;fontColor=#244B2F;" vertex="1" parent="1"><mxGeometry x="50" y="140" width="400" height="60" as="geometry"/></mxCell>
        <mxCell id="g1" value="&lt;b&gt;Python 安装范围&lt;/b&gt;&lt;br/&gt;python_requires &amp;gt;= 3.9" style="rounded=1;arcSize=7;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#4C9B60;strokeWidth=2;fontSize=14;fontColor=#172033;spacing=7;" vertex="1" parent="1"><mxGeometry x="60" y="225" width="380" height="75" as="geometry"/></mxCell>
        <mxCell id="g2" value="&lt;b&gt;CANN 环境&lt;/b&gt;&lt;br/&gt;构建和调用前必须完成初始化" style="rounded=1;arcSize=7;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#4C9B60;strokeWidth=2;fontSize=14;fontColor=#172033;spacing=7;" vertex="1" parent="1"><mxGeometry x="60" y="325" width="380" height="75" as="geometry"/></mxCell>
        <mxCell id="g3" value="&lt;b&gt;内嵌 OPP 完整性&lt;/b&gt;&lt;br/&gt;op_api / op_host / tiling / kernel 同树交付" style="rounded=1;arcSize=7;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#4C9B60;strokeWidth=2;fontSize=14;fontColor=#172033;spacing=7;" vertex="1" parent="1"><mxGeometry x="60" y="425" width="380" height="75" as="geometry"/></mxCell>
        <mxCell id="g4" value="&lt;b&gt;动态加载&lt;/b&gt;&lt;br/&gt;绝对路径 + RTLD_NOW 暴露缺库和缺符号" style="rounded=1;arcSize=7;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#4C9B60;strokeWidth=2;fontSize=14;fontColor=#172033;spacing=7;" vertex="1" parent="1"><mxGeometry x="60" y="525" width="380" height="75" as="geometry"/></mxCell>
        <mxCell id="g5" value="&lt;b&gt;调用检查&lt;/b&gt;&lt;br/&gt;NPU tensor / dtype / descriptor / ACL 返回值" style="rounded=1;arcSize=7;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#4C9B60;strokeWidth=2;fontSize=14;fontColor=#172033;spacing=7;" vertex="1" parent="1"><mxGeometry x="60" y="625" width="380" height="75" as="geometry"/></mxCell>

        <mxCell id="amber-header" value="&lt;b&gt;当前尚未形成硬门禁&lt;/b&gt;" style="rounded=1;arcSize=7;whiteSpace=wrap;html=1;fillColor=#FFF4D8;strokeColor=#D9970B;strokeWidth=2;fontSize=18;fontColor=#6A4A00;" vertex="1" parent="1"><mxGeometry x="550" y="140" width="400" height="60" as="geometry"/></mxCell>
        <mxCell id="a1" value="&lt;b&gt;SOC / host build tag&lt;/b&gt;&lt;br/&gt;py3-none-any 不会让 pip 自动判错" style="rounded=1;arcSize=7;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#D9970B;strokeWidth=2;fontSize=14;fontColor=#172033;spacing=7;" vertex="1" parent="1"><mxGeometry x="560" y="225" width="380" height="75" as="geometry"/></mxCell>
        <mxCell id="a2" value="&lt;b&gt;CANN 运行版本范围&lt;/b&gt;&lt;br/&gt;当前能读取版本，但未在 import 时强制范围" style="rounded=1;arcSize=7;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#D9970B;strokeWidth=2;fontSize=14;fontColor=#172033;spacing=7;" vertex="1" parent="1"><mxGeometry x="560" y="325" width="380" height="75" as="geometry"/></mxCell>
        <mxCell id="a3" value="&lt;b&gt;torch / torch_npu 配套关系&lt;/b&gt;&lt;br/&gt;不在 install_requires 中，也未显式比对发布族" style="rounded=1;arcSize=7;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#D9970B;strokeWidth=2;fontSize=14;fontColor=#172033;spacing=7;" vertex="1" parent="1"><mxGeometry x="560" y="425" width="380" height="75" as="geometry"/></mxCell>
        <mxCell id="a4" value="&lt;b&gt;环境检查脚本&lt;/b&gt;&lt;br/&gt;可检查最低版本，但安装后不会自动运行" style="rounded=1;arcSize=7;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#D9970B;strokeWidth=2;fontSize=14;fontColor=#172033;spacing=7;" vertex="1" parent="1"><mxGeometry x="560" y="525" width="380" height="75" as="geometry"/></mxCell>
        <mxCell id="a5" value="&lt;b&gt;同名符号后的 ABI 变化&lt;/b&gt;&lt;br/&gt;签名变化和 libstdc++ 基线仍需测试发现" style="rounded=1;arcSize=7;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#D9970B;strokeWidth=2;fontSize=14;fontColor=#172033;spacing=7;" vertex="1" parent="1"><mxGeometry x="560" y="625" width="380" height="75" as="geometry"/></mxCell>

        <mxCell id="blue-header" value="&lt;b&gt;推荐的完整闭环&lt;/b&gt;" style="rounded=1;arcSize=7;whiteSpace=wrap;html=1;fillColor=#E8F1FF;strokeColor=#5B7DB1;strokeWidth=2;fontSize=18;fontColor=#24466F;" vertex="1" parent="1"><mxGeometry x="1050" y="140" width="400" height="60" as="geometry"/></mxCell>
        <mxCell id="b1" value="&lt;b&gt;compatibility.json&lt;/b&gt;&lt;br/&gt;记录版本、commit、SOC、架构和 CANN 范围" style="rounded=1;arcSize=7;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#5B7DB1;strokeWidth=2;fontSize=14;fontColor=#172033;spacing=7;" vertex="1" parent="1"><mxGeometry x="1060" y="225" width="380" height="75" as="geometry"/></mxCell>
        <mxCell id="b2" value="&lt;b&gt;一次性 preflight&lt;/b&gt;&lt;br/&gt;首次 kernel 前检查 host / SOC / CANN" style="rounded=1;arcSize=7;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#5B7DB1;strokeWidth=2;fontSize=14;fontColor=#172033;spacing=7;" vertex="1" parent="1"><mxGeometry x="1060" y="325" width="380" height="75" as="geometry"/></mxCell>
        <mxCell id="b3" value="&lt;b&gt;符号和 ABI 指纹&lt;/b&gt;&lt;br/&gt;检查公共 ACL、aclnn 符号与 header 清单" style="rounded=1;arcSize=7;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#5B7DB1;strokeWidth=2;fontSize=14;fontColor=#172033;spacing=7;" vertex="1" parent="1"><mxGeometry x="1060" y="425" width="380" height="75" as="geometry"/></mxCell>
        <mxCell id="b4" value="&lt;b&gt;框架能力探测&lt;/b&gt;&lt;br/&gt;检查 NPU tensor / storage / stream，不锁 torch patch" style="rounded=1;arcSize=7;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#5B7DB1;strokeWidth=2;fontSize=14;fontColor=#172033;spacing=7;" vertex="1" parent="1"><mxGeometry x="1060" y="525" width="380" height="75" as="geometry"/></mxCell>
        <mxCell id="b5" value="&lt;b&gt;交付闭环&lt;/b&gt;&lt;br/&gt;run 覆盖同步清单；CI 由清单校验支持矩阵" style="rounded=1;arcSize=7;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#5B7DB1;strokeWidth=2;fontSize=14;fontColor=#172033;spacing=7;" vertex="1" parent="1"><mxGeometry x="1060" y="625" width="380" height="75" as="geometry"/></mxCell>

        <mxCell id="result" value="&lt;b&gt;目标：不锁死 torch minor / patch，但在首次 kernel enqueue 前拒绝错误环境&lt;/b&gt;&lt;br/&gt;SOC、host、CANN、ACL 符号和框架能力可解释地失败；发布矩阵只声明真实验证组合" style="rounded=1;arcSize=7;whiteSpace=wrap;html=1;fillColor=#EEF6FF;strokeColor=#3973B7;strokeWidth=2.5;fontSize=16;fontColor=#1F466F;spacing=10;" vertex="1" parent="1"><mxGeometry x="180" y="790" width="1140" height="100" as="geometry"/></mxCell>

